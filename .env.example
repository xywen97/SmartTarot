# AI 塔罗占卜系统 - 环境变量配置示例
# 复制此文件为 .env 并填写实际值

# ============================================
# Claude AI API 配置（必需）
# ============================================

# 你的 API Key（必需）
# 获取方式：访问 https://poloai.top 注册并生成
POLOAI_API_KEY=sk-your-api-key-here

# API 基础 URL（必需）
POLOAI_BASE_URL=https://poloai.top

# 使用的模型（必需）
# 可选值: claude-opus-4-8, claude-sonnet-4-6, claude-haiku-4-5
MODEL=claude-opus-4-8

# ============================================
# 服务配置（可选）
# ============================================

# 调试模式
# 开发环境: True, 生产环境: False
DEBUG=True

# CORS 允许的源（用逗号分隔，可选）
# 留空 + DEBUG=True 时自动允许所有来源（本机/服务器 IP 均可，无需写死）
# CORS_ORIGINS=*

# 生产环境（使用 Nginx 同源反代时可不配置 CORS）
# CORS_ORIGINS=https://your-domain.com,https://www.your-domain.com
